# BunnyBet Contracts — Environment Variables
# Copy to .env — NEVER commit .env to git

# Deployer wallet private key (no 0x prefix)
PRIVATE_KEY=your_private_key_here

# MegaETH Mainnet RPC
MEGAETH_RPC_URL=https://mainnet.megaeth.com/rpc

# Block explorer API keys (for --verify)
# Blockscout: any non-empty string works
BLOCKSCOUT_API_KEY=anystring
# mega.etherscan.io: get from their site (may not require key)
ETHERSCAN_API_KEY=

# Set to true to deploy a demo market alongside factory
SEED_MARKET=false

# ── These are already hardcoded in Deploy.s.sol ──────────────────────────────
