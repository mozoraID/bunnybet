# BunnyBet Frontend — copy to .env.local

# ── Contract addresses (REQUIRED after deploy) ────────────────────────────────
NEXT_PUBLIC_FACTORY_ADDRESS=0xYourDeployedFactoryAddressHere

# ── USDM Token on MegaETH Mainnet (hardcoded — don't change) ─────────────────
NEXT_PUBLIC_USDM_ADDRESS=0xFAfDdbb3FC7688494971a79cc65DCa3EF82079E7

# ── MegaETH RPC ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://mainnet.megaeth.com/rpc
NEXT_PUBLIC_WS_URL=wss://mainnet.megaeth.com/ws

# ── WalletConnect (get from https://cloud.walletconnect.com) ──────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id